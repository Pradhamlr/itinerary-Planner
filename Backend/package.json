{
  "name": "smart-itinerary-planner-backend",
  "version": "1.0.0",
  "description": "Backend foundation for Smart Itinerary Planner",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test",
    "export-dataset": "node scripts/exportPlacesDataset.js",
    "enrich-reviews": "node scripts/enrichPlaceReviews.js",
    "enrich-shopping": "node scripts/enrichShoppingPlaces.js",
    "cleanup-shopping-preview": "node scripts/cleanupShoppingMallNoise.js",
    "cleanup-shopping-apply": "node scripts/cleanupShoppingMallNoise.js --apply",
    "cleanup-shopping-delete": "node scripts/cleanupShoppingMallNoise.js --delete",
    "sync-shopping-targets": "node scripts/syncSpecificShoppingPlaces.js",
    "preview-city-plan": "node scripts/previewCityExpansionPlan.js",
    "fetch-city-batch": "node scripts/fetchPlannedCities.js",
    "fetch-next-expansion-batch": "node scripts/fetchNextExpansionBatch.js",
    "export-expansion-dataset": "node scripts/exportExpansionDataset.js",
    "reset-expansion-cities": "node scripts/resetExpansionCities.js",
    "sync-hotels": "node scripts/syncHotels.js",
    "sync-hotels-expansion": "node scripts/syncHotels.js --priority 1",
    "enrich-hotels": "node scripts/enrichHotelsHeuristically.js"
  },
  "keywords": [
    "travel",
    "itinerary",
    "planning"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.5.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "ml-kmeans": "^6.0.0",
    "mongoose": "^7.5.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
